# =============================================================================
# Luna / AI YOU — 环境变量模板
# 使用方式：复制本文件为 .env，把下方占位值换成你的真实密钥，勿提交 .env
# =============================================================================

# -----------------------------------------------------------------------------
# AI 直连（未登录网关时，本地选模型对话）
# -----------------------------------------------------------------------------
# 可选：none（仅经已登录私聊/网关，不校对本机 API Key）| openai | gemini | claude
EXPO_PUBLIC_AI_PROVIDER=none

# OpenAI — https://platform.openai.com/api-keys
EXPO_PUBLIC_OPENAI_API_KEY=your-openai-key-here

# Google Gemini — https://aistudio.google.com/apikey
EXPO_PUBLIC_GEMINI_API_KEY=your-gemini-key-here

# Anthropic Claude — https://console.anthropic.com/
EXPO_PUBLIC_CLAUDE_API_KEY=your-claude-key-here

# -----------------------------------------------------------------------------
# AIYOU 网关（登录、私人聊天、知识库等）
# -----------------------------------------------------------------------------
EXPO_PUBLIC_DEV_API_BASE_URL=https://aiyou.ontuotu.com

# -----------------------------------------------------------------------------
# 私人聊天默认模型名（可选；不设则回退代码内默认）
# 三选一或都留空；实际展示列表仍以后端为准
# -----------------------------------------------------------------------------
# EXPO_PUBLIC_PRIVATE_CHAT_MODEL_OPENAI=
# EXPO_PUBLIC_PRIVATE_CHAT_MODEL_CLAUDE=
# EXPO_PUBLIC_PRIVATE_CHAT_MODEL_GEMINI=

# 私人模式子模式等（可选，见 lib/privateChatApi.ts）
# EXPO_PUBLIC_PRIVATE_CHAT_SUBMODE=flash
# EXPO_PUBLIC_PRIVATE_CHAT_MULTITASK_STRATEGY=reject

# -----------------------------------------------------------------------------
# 腾讯混元 TokenHub（图生图 / 初始化模型数字形象）
# -----------------------------------------------------------------------------
EXPO_PUBLIC_TENCENT_MAAS_API_KEY=your-tokenhub-key-here

# -----------------------------------------------------------------------------
# 初始化模型 · 声音复刻通道：aliyun（默认，可不配）| tencent
# 仅当需要切回腾讯云 VRS 时设为 tencent
# -----------------------------------------------------------------------------
EXPO_PUBLIC_VOICE_CLONE_PROVIDER=aliyun

# -----------------------------------------------------------------------------
# 腾讯声音复刻 VRS（初始化模型声音采集）
# -----------------------------------------------------------------------------
EXPO_PUBLIC_TENCENT_VOICE_SECRET_ID=your-tencent-secret-id
EXPO_PUBLIC_TENCENT_VOICE_SECRET_KEY=your-tencent-secret-key
EXPO_PUBLIC_TENCENT_VOICE_REGION=ap-guangzhou
# 可选：固定训练文本 ID，不设则由接口拉取
# EXPO_PUBLIC_TENCENT_VOICE_TEXT_ID=

# -----------------------------------------------------------------------------
# 阿里云百炼 DashScope（CosyVoice 声音复刻 / 音色调试页）
# API Key：https://help.aliyun.com/zh/model-studio/get-api-key
# 北京与新加坡地域 Key 不同，须与 BASE_URL 一致
# -----------------------------------------------------------------------------
EXPO_PUBLIC_ALIYUN_DASHSCOPE_API_KEY=your-aliyun-dashscope-api-key
# 中国内地（北京）
EXPO_PUBLIC_ALIYUN_DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/api/v1
# 国际（新加坡）示例：https://dashscope-intl.aliyuncs.com/api/v1
EXPO_PUBLIC_ALIYUN_TTS_TARGET_MODEL=cosyvoice-v3.5-plus

# -----------------------------------------------------------------------------
# 百炼工作流应用（侧边栏「专家通话调试」）
# 应用 ID：控制台应用卡片；Key 可与上方 EXPO_PUBLIC_ALIYUN_DASHSCOPE_API_KEY 相同
# -----------------------------------------------------------------------------
# EXPO_PUBLIC_BAILIAN_APP_ID=your-app-id
# EXPO_PUBLIC_BAILIAN_API_KEY=sk-your-key
# 可选，默认北京：https://dashscope.aliyuncs.com/api/v1
# EXPO_PUBLIC_BAILIAN_BASE_URL=https://dashscope.aliyuncs.com/api/v1
# 工作流为非流式时必须关闭增量（否则客户端仍走 SSE，耗时会明显变长）：
# EXPO_PUBLIC_BAILIAN_WORKFLOW_INCREMENTAL_OUTPUT=false

# -----------------------------------------------------------------------------
# 阿里云智能语音 · 实时语音识别调试（侧边栏「实时语音调试」）
# Token 须由服务端签发；本地调试请先运行：npm run dev:nls-token（见 dev-servers/aliyun-nls-token）
# 本地：EXPO_PUBLIC_NLS_TOKEN_URL=http://127.0.0.1:18765（Android 模拟器可用 10.0.2.2）
# 线上：填 https://your-domain.com 或 https://your-domain.com/nls/token 均可
# -----------------------------------------------------------------------------
# EXPO_PUBLIC_NLS_TOKEN_URL=http://127.0.0.1:18765
# EXPO_PUBLIC_NLS_TOKEN_URL=https://aiyou.ontuotu.com
EXPO_PUBLIC_ALIYUN_NLS_APPKEY=your-nls-project-appkey
# 可选，默认上海网关
# EXPO_PUBLIC_ALIYUN_NLS_GATEWAY_WSS=wss://nls-gateway-cn-shanghai.aliyuncs.com/ws/v1
# 实时识别调优（默认开启语义断句；报错时可设 false）：EXPO_PUBLIC_NLS_ENABLE_SEMANTIC_SENTENCE=false
# 控制台泛热词表 ID：# EXPO_PUBLIC_NLS_VOCABULARY_ID=your_vocab_id
# 自学习模型 ID：# EXPO_PUBLIC_NLS_CUSTOMIZATION_ID=your_model_id
# 断句静音阈值 ms（200～2000）：# EXPO_PUBLIC_NLS_MAX_SENTENCE_SILENCE=1100
# 远场/环境误识别：speech_noise_threshold [-1,1]，趋近 +1 更强抑制噪声（可能误伤轻声）
# 建议扫参 0.25 → 0.55，勿过快调到 0.8+；不配则走阿里云默认
# EXPO_PUBLIC_NLS_SPEECH_NOISE_THRESHOLD=0.35
# 生产包若需保留调试入口，显式设为 true（默认仅 __DEV__ 显示）
# EXPO_PUBLIC_ENABLE_NLS_DEBUG=true
# 侧边栏：音色调试、专家通话调试（百炼工作流）等；不设则仅 __DEV__ 显示
# EXPO_PUBLIC_ENABLE_SIDEBAR_DEBUG=true

# 阿里云 OSS（客户端直传：密钥会打进安装包，生产环境建议改为 STS 临时凭证）
EXPO_PUBLIC_ALIYUN_OSS_ACCESS_KEY_ID=your-aliyun-oss-access-key-id
EXPO_PUBLIC_ALIYUN_OSS_ACCESS_KEY_SECRET=your-aliyun-oss-access-key-secret
EXPO_PUBLIC_ALIYUN_OSS_BUCKET=your-bucket-name
EXPO_PUBLIC_ALIYUN_OSS_ENDPOINT=oss-cn-hangzhou.aliyuncs.com

# -----------------------------------------------------------------------------
# 微信分享（对话工具栏 → 微信会话链接卡片）；需微信开放平台移动应用 AppID，并 npx expo prebuild 后重编原生包
# EXPO_PUBLIC_WECHAT_APP_ID=wxxxxxxxxxxxxxxxx
# iOS 需在苹果开发者与域名配置 Universal Links 后与开放平台一致
# EXPO_PUBLIC_WECHAT_IOS_UNIVERSAL_LINK=https://your-domain.com/
# 卡片点击打开的 https 落地页；不配则使用 EXPO_PUBLIC_DEV_API_BASE_URL 首页
# EXPO_PUBLIC_CHAT_SHARE_WEB_URL=https://your-domain.com/chat-share
# 卡片缩略图，需公网可访问的 https 图片（建议 ≤300px）
# EXPO_PUBLIC_CHAT_SHARE_THUMB_URL=https://your-domain.com/share-thumb.png

# -----------------------------------------------------------------------------
# 开发者工具（仅 Web：npx expo start --web 后访问 /dev）
# 生产构建勿设为 true
# -----------------------------------------------------------------------------
# EXPO_PUBLIC_DEV_TOOLS=true
