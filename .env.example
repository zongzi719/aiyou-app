# AI Provider Configuration
# Copy this file to .env and add your API keys

# Choose your AI provider: openai | gemini | claude
EXPO_PUBLIC_AI_PROVIDER=openai

# OpenAI (ChatGPT)
# Get your key at: https://platform.openai.com/api-keys
EXPO_PUBLIC_OPENAI_API_KEY=your-openai-key-here

# Google Gemini
# Get your key at: https://makersuite.google.com/app/apikey
EXPO_PUBLIC_GEMINI_API_KEY=your-gemini-key-here

# Anthropic Claude
# Get your key at: https://console.anthropic.com/
EXPO_PUBLIC_CLAUDE_API_KEY=your-claude-key-here

# AIYOU 网关（移动端登录、私人聊天、知识库等；默认直连线上，无需本机代理）
EXPO_PUBLIC_DEV_API_BASE_URL=http://47.242.248.240:2026

# Dev Tools（仅 Web：npx expo start --web 后浏览器打开 /dev）
# 生产 Web 构建默认关闭 /dev；仅内网预览需要时设为 true
# EXPO_PUBLIC_DEV_TOOLS=true
