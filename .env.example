# =============================================================================
# Luna / AI YOU — 环境变量模板
# 使用方式：复制本文件为 .env，把下方占位值换成你的真实密钥，勿提交 .env
# =============================================================================

# -----------------------------------------------------------------------------
# AI 直连（未登录网关时，本地选模型对话）
# -----------------------------------------------------------------------------
# 可选：openai | gemini | claude
EXPO_PUBLIC_AI_PROVIDER=openai

# OpenAI — https://platform.openai.com/api-keys
EXPO_PUBLIC_OPENAI_API_KEY=your-openai-key-here

# Google Gemini — https://aistudio.google.com/apikey
EXPO_PUBLIC_GEMINI_API_KEY=your-gemini-key-here

# Anthropic Claude — https://console.anthropic.com/
EXPO_PUBLIC_CLAUDE_API_KEY=your-claude-key-here

# -----------------------------------------------------------------------------
# AIYOU 网关（登录、私人聊天、知识库等）
# -----------------------------------------------------------------------------
EXPO_PUBLIC_DEV_API_BASE_URL=http://47.242.248.240:2026

# -----------------------------------------------------------------------------
# 私人聊天默认模型名（可选；不设则回退代码内默认）
# 三选一或都留空；实际展示列表仍以后端为准
# -----------------------------------------------------------------------------
# EXPO_PUBLIC_PRIVATE_CHAT_MODEL_OPENAI=
# EXPO_PUBLIC_PRIVATE_CHAT_MODEL_CLAUDE=
# EXPO_PUBLIC_PRIVATE_CHAT_MODEL_GEMINI=

# 私人模式子模式等（可选，见 lib/privateChatApi.ts）
# EXPO_PUBLIC_PRIVATE_CHAT_SUBMODE=flash
# EXPO_PUBLIC_PRIVATE_CHAT_MULTITASK_STRATEGY=reject

# -----------------------------------------------------------------------------
# 腾讯混元 TokenHub（图生图 / 初始化模型数字形象）
# -----------------------------------------------------------------------------
EXPO_PUBLIC_TENCENT_MAAS_API_KEY=your-tokenhub-key-here

# -----------------------------------------------------------------------------
# 初始化模型 · 声音复刻通道：aliyun（默认，可不配）| tencent
# 仅当需要切回腾讯云 VRS 时设为 tencent
# -----------------------------------------------------------------------------
EXPO_PUBLIC_VOICE_CLONE_PROVIDER=aliyun

# -----------------------------------------------------------------------------
# 腾讯声音复刻 VRS（初始化模型声音采集）
# -----------------------------------------------------------------------------
EXPO_PUBLIC_TENCENT_VOICE_SECRET_ID=your-tencent-secret-id
EXPO_PUBLIC_TENCENT_VOICE_SECRET_KEY=your-tencent-secret-key
EXPO_PUBLIC_TENCENT_VOICE_REGION=ap-guangzhou
# 可选：固定训练文本 ID，不设则由接口拉取
# EXPO_PUBLIC_TENCENT_VOICE_TEXT_ID=

# -----------------------------------------------------------------------------
# 阿里云百炼 DashScope（CosyVoice 声音复刻 / 音色调试页）
# API Key：https://help.aliyun.com/zh/model-studio/get-api-key
# 北京与新加坡地域 Key 不同，须与 BASE_URL 一致
# -----------------------------------------------------------------------------
EXPO_PUBLIC_ALIYUN_DASHSCOPE_API_KEY=your-aliyun-dashscope-api-key
# 中国内地（北京）
EXPO_PUBLIC_ALIYUN_DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/api/v1
# 国际（新加坡）示例：https://dashscope-intl.aliyuncs.com/api/v1
EXPO_PUBLIC_ALIYUN_TTS_TARGET_MODEL=cosyvoice-v3.5-plus

# 阿里云 OSS（客户端直传：密钥会打进安装包，生产环境建议改为 STS 临时凭证）
EXPO_PUBLIC_ALIYUN_OSS_ACCESS_KEY_ID=your-aliyun-oss-access-key-id
EXPO_PUBLIC_ALIYUN_OSS_ACCESS_KEY_SECRET=your-aliyun-oss-access-key-secret
EXPO_PUBLIC_ALIYUN_OSS_BUCKET=your-bucket-name
EXPO_PUBLIC_ALIYUN_OSS_ENDPOINT=oss-cn-hangzhou.aliyuncs.com

# -----------------------------------------------------------------------------
# 开发者工具（仅 Web：npx expo start --web 后访问 /dev）
# 生产构建勿设为 true
# -----------------------------------------------------------------------------
# EXPO_PUBLIC_DEV_TOOLS=true
