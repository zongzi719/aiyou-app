{
  "expo": {
    "newArchEnabled": true,
    "name": "AIYOU",
    "slug": "luna-zhouyz719",
    "version": "1.2.0",
    "runtimeVersion": "1.2.0",
    "scheme": "luna",
    "experiments": {
      "tsconfigPaths": true
    },
    "platforms": [
      "ios",
      "android",
      "web"
    ],
    "plugins": [
      "expo-router",
      "expo-font",
      "expo-audio",
      "expo-stream-audio"
    ],
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "bundleIdentifier": "com.lmrj.lmaiyou",
      "buildNumber": "5",
      "supportsTablet": true,
      "infoPlist": {
        "LSApplicationQueriesSchemes": ["weixin", "weixinULAPI"],
        "NSMicrophoneUsageDescription": "This app uses the microphone for speech-to-text functionality.",
        "NSAppTransportSecurity": {
          "NSAllowsArbitraryLoads": true,
          "NSAllowsLocalNetworking": true
        }
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "softwareKeyboardLayoutMode": "resize",
      "predictiveBackGestureEnabled": false,
      "config": {
        "enableOnBackInvokedCallback": false
      },
      "navigationBarColor": "transparent",
      "navigationBarHidden": true,
      "package": "com.lmrj.lmaiyou",
      "permissions": [
        "android.permission.RECORD_AUDIO",
        "android.permission.MODIFY_AUDIO_SETTINGS"
      ],
      "usesCleartextTraffic": true
    },
    "extra": {
      "router": {
        "origin": false
      },
      "eas": {
        "projectId": "38b487fc-380f-4e72-8d4a-6c9e85bb8100"
      }
    },
    "owner": "zhouyz719"
  }
}
